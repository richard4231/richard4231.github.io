# Application
APP_NAME=SLMS API
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-secrets-generate

# Database
DATABASE_URL=postgresql+asyncpg://slms:slms@localhost:5432/slms

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# SWITCH edu-ID (OIDC)
# Get credentials from: https://eduid.ch/web/developers/
EDUID_CLIENT_ID=
EDUID_CLIENT_SECRET=
EDUID_ISSUER=https://login.test.eduid.ch
EDUID_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# JWT (generate with: openssl genrsa -out private.pem 2048)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Email (SMTP)
SMTP_HOST=smtp.mailjet.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@slms.localhost
SMTP_FROM_NAME=SLMS System

# S3 Storage (Exoscale)
S3_ENDPOINT=https://sos-ch-gva-2.exo.io
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=slms-documents
S3_REGION=ch-gva-2

# Sentry (optional)
SENTRY_DSN=

# Waitlist
DEFAULT_WAITLIST_THRESHOLD=30
